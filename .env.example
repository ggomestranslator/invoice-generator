# Copy this file to .env and fill in your real values.
# Never commit .env — it contains real business data.

# ==== Company Information ====
COMPANY_NAME="<YOUR_COMPANY_NAME>"  # The name of the company
COMPANY_ID="<YOUR_CNPJ>"  # The company identification number (e.g., CNPJ)

# ==== Billing Information ====
BILLING_ADDRESS="<YOUR_BILLING_ADDRESS>"  # The billing address

# ==== Bank Information (Brazilian domestic) ====
BANK_NAME="<YOUR_BANK>"  # The name of the bank
BANK_CODE="<CODE>"  # The Brazilian bank code (Código do banco)
BANK_BRANCH="<BRANCH>"  # The branch number (Agência)
BANK_ACCOUNT="<ACCOUNT>"  # The account number (Conta)
BENEFICIARY_CNPJ="<YOUR_CNPJ>"  # The beneficiary's CNPJ
PIX_KEY="<YOUR_PIX_KEY>"  # The PIX key

# ==== Contact Information ====
SUPPORT_EMAIL="<YOUR_EMAIL>"  # The support email address
BENEFICIARY_NAME="<YOUR_NAME>"  # The beneficiary's name

# ==== Service Information ====
SERVICE_TITLE="<SERVICE_TITLE>"  # The title of the service
SERVICE_DESC="<SERVICE_DESCRIPTION>"  # The service description
CURRENCY="BRL"  # The currency used in the invoice (e.g., GBP, USD, EUR)

# ==== Billing Party Information ====
BILL_TO="<CLIENT_NAME>\n<CLIENT_ADDRESS>\n<CLIENT_CITY_COUNTRY>"  # Client address (use \n for line breaks)
BILL_FROM="<YOUR_COMPANY>\n<YOUR_ADDRESS>\n<YOUR_CITY_STATE>"  # Issuer address (use \n for line breaks)
